{
  "layer": "top",
  "position": "top",
  "height": 18,
  "spacing": 0,
  "margin": 0,
  "exclusive": true,
  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-center": [],
  "modules-right": ["custom/codexbar", "pulseaudio", "custom/computer-status", "tray"],
  "niri/workspaces": {
    "format": "{value}",
    "disable-scroll": true
  },
  "niri/window": {
    "format": " {app_id}",
    "separate-outputs": false,
    "max-length": 40
  },
  "custom/computer-status": {
    "exec": "/home/jake/.dotfiles/waybar/computer-status",
    "format": "{}",
    "interval": 5,
    "tooltip": false,
    "escape": false
  },
  "custom/codexbar": {
    "exec": "codexbar",
    "return-type": "json",
    "interval": 300,
    "signal": 12,
    "tooltip": true,
    "on-click": "xdg-open https://chatgpt.com/codex/settings/usage"
  },
  "pulseaudio": {
    "format": "| S: {volume}%",
    "format-bluetooth": "| S: {volume}% (H)",
    "format-muted": "| S: muted",
    "format-bluetooth-muted": "| S: muted (H)",
    "tooltip": false,
    "on-click": "pavucontrol"
  },
  "tray": {
    "icon-size": 14,
    "spacing": 4
  }
}
