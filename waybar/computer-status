#!/usr/bin/env bash
set -u

first_line() {
    awk 'NF { print; exit }' "$1" 2>/dev/null
}

colorize() {
    printf '<span foreground="%s">%s</span>' "$1" "$2"
}

iface_ip() {
    ip -4 addr show dev "$1" 2>/dev/null | awk '/inet / { sub("/.*", "", $2); print $2; exit }'
}

default_iface() {
    ip route get 1.1.1.1 2>/dev/null | awk '{ for (i = 1; i <= NF; i++) if ($i == "dev") { print $(i + 1); exit } }'
}

is_wifi_iface() {
    local iface="$1"

    [[ -d "/sys/class/net/${iface}/wireless" ]] && return 0
    grep -qx 'DEVTYPE=wlan' "/sys/class/net/${iface}/uevent" 2>/dev/null && return 0
    command -v iw >/dev/null 2>&1 && iw dev "${iface}" info >/dev/null 2>&1 && return 0
    command -v nmcli >/dev/null 2>&1 && [[ "$(nmcli -t -g GENERAL.TYPE dev show "${iface}" 2>/dev/null)" == "wifi" ]] && return 0

    return 1
}

first_wifi_iface() {
    local iface iface_path

    iface="$(default_iface)"
    if [[ -n "${iface}" ]] && is_wifi_iface "${iface}"; then
        printf '%s\n' "${iface}"
        return
    fi

    for iface_path in /sys/class/net/*; do
        iface="${iface_path##*/}"
        if is_wifi_iface "${iface}"; then
            printf '%s\n' "${iface}"
            return
        fi
    done
}

first_ethernet_iface() {
    local iface iface_path

    iface="$(default_iface)"
    if [[ -n "${iface}" && "${iface}" != "lo" ]] && ! is_wifi_iface "${iface}"; then
        printf '%s\n' "${iface}"
        return
    fi

    for iface_path in /sys/class/net/*; do
        iface="${iface_path##*/}"
        [[ "${iface}" != "lo" ]] || continue
        is_wifi_iface "${iface}" && continue
        [[ "$(first_line "/sys/class/net/${iface}/type")" == "1" ]] || continue
        printf '%s\n' "${iface}"
        return
    done
}

disk="$(df -h / 2>/dev/null | awk 'NR == 2 { print $4 }')"
[[ -n "${disk}" ]] || disk="?"
space="Free space: ${disk}"
if awk '$2 == "/data" { found = 1 } END { exit !found }' /proc/mounts 2>/dev/null; then
    data_disk="$(df -h /data 2>/dev/null | awk 'NR == 2 { print $4 }')"
    [[ -n "${data_disk}" ]] || data_disk="?"
    space="${space}, ${data_disk}"
fi

ram_used="$(awk '
    /^MemTotal:/ { total = $2 }
    /^MemAvailable:/ { available = $2 }
    END {
        if (total > 0 && available > 0) {
            used = total - available
            printf "%.1fG", used / 1024 / 1024
        }
    }
' /proc/meminfo 2>/dev/null)"
[[ -n "${ram_used}" ]] || ram_used="?"
ram="RAM: ${ram_used}"

wifi_iface="$(first_wifi_iface)"
if [[ -n "${wifi_iface}" ]]; then
    wifi_ip="$(iface_ip "${wifi_iface}")"
    if [[ -n "${wifi_ip}" ]]; then
        quality="$(awk -v iface="${wifi_iface}:" '$1 == iface { gsub("\\.", "", $3); printf "%d%%", ($3 / 70) * 100 }' /proc/net/wireless 2>/dev/null)"
        [[ -n "${quality}" ]] || quality="up"
        wifi="$(colorize "#00ff00" "W: (${quality}) ${wifi_ip}")"
    else
        wifi="$(colorize "#ff0000" "W: down")"
    fi
else
    wifi="$(colorize "#ff0000" "W: down")"
fi

ethernet_iface="$(first_ethernet_iface)"
ethernet="$(colorize "#ff0000" "E: down")"
if [[ -n "${ethernet_iface}" ]]; then
    ethernet_ip="$(iface_ip "${ethernet_iface}")"
    if [[ -n "${ethernet_ip}" ]]; then
        speed="$(first_line "/sys/class/net/${ethernet_iface}/speed")"
        if [[ "${speed}" =~ ^[0-9]+$ ]]; then
            ethernet="$(colorize "#00ff00" "E: ${ethernet_ip} (${speed} Mbit/s)")"
        else
            ethernet="$(colorize "#00ff00" "E: ${ethernet_ip}")"
        fi
    fi
fi

status_parts=("${space}" "${ram}" "${wifi}" "${ethernet}")

if /home/jake/.dotfiles/waybar/is-laptop; then
    battery="Battery: AC"
    for bat in /sys/class/power_supply/BAT*; do
        [[ -r "${bat}/capacity" ]] || continue
        capacity="$(first_line "${bat}/capacity")"
        status="$(first_line "${bat}/status")"
        [[ -n "${capacity}" ]] || capacity="?"
        [[ -n "${status}" ]] || status="?"
        battery="Battery: ${capacity}% ${status}"
        break
    done
    status_parts+=("${battery}")
fi

load_str="$(awk '{ print $1 }' /proc/loadavg 2>/dev/null)"
[[ -n "${load_str}" ]] || load_str="?"
load="Load: ${load_str}"

now="$(date '+%Y-%m-%d %H:%M:%S')"
status_parts+=("${load}" "${now}")

printf '| '
printf '%s' "${status_parts[0]}"
for part in "${status_parts[@]:1}"; do
    printf ' | %s' "${part}"
done
printf '\n'
